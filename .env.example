# Flask Configuration
SECRET_KEY=your_secret_key_here_change_in_production
FLASK_ENV=development
FLASK_DEBUG=True

# Database Configuration
DATABASE_URL=sqlite:///auction.db
# For production use PostgreSQL:
# DATABASE_URL=postgresql://username:password@host:port/database_name

# Stripe Payment Configuration
# Get these from your Stripe Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Upload Configuration
UPLOAD_FOLDER=auction7/app/static/images/uploads
MAX_CONTENT_LENGTH=16777216  # 16MB max file size
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp

# OpenAI Configuration (for assistant)
OPENAI_API_KEY=your_openai_api_key_here

# Web3/Blockchain Configuration (if using crypto features)
WEB3_PROVIDER_URL=https://mainnet.infura.io/v3/your_infura_project_id
BLOCKCHAIN_NETWORK=mainnet

# Email Configuration (for notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here

# Admin Configuration
ADMIN_EMAIL=admin@auction7.com
PLATFORM_FEE_PERCENTAGE=5.0  # Platform fee percentage

# Security
SESSION_PERMANENT=False
SESSION_TYPE=filesystem
PERMANENT_SESSION_LIFETIME=1800  # 30 minutes