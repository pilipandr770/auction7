# ──────────────────────────────────────────────
# Flask core
# ──────────────────────────────────────────────
# PFLICHT: zufälliger Wert, z.B.: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_RANDOM_VALUE
DATABASE_URL=sqlite:///auction.db          # PostgreSQL для продакшну: postgresql://user:pass@host/db

# ──────────────────────────────────────────────
# Blockchain (Polygon / MATIC)
# ──────────────────────────────────────────────
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com
PRIVATE_KEY=0x...                          # приватний ключ платіжного гаманця платформи
ACCOUNT_ADDRESS=0x...                      # адреса платіжного гаманця платформи
CONTRACT_ADDRESS=0x...                     # адреса смарт-контракту AUKTO токену
ESCROW_ADDRESS=0x...                       # адреса ескроу гаманця
ESCROW_PRIVATE_KEY=0x...                   # приватний ключ ескроу гаманця
ADMIN_ADDRESS=0x...                        # адреса адмін-гаманця (комісії за перегляд)

# ──────────────────────────────────────────────
# OpenAI (AI-асистент + Whisper)
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────
# Stripe (платежі, Connect Express, ЕС/EUR)
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...           # секретний ключ (test mode для розробки)
STRIPE_PUBLISHABLE_KEY=pk_test_...       # публічний ключ (для Stripe.js на фронті)
STRIPE_WEBHOOK_SECRET=whsec_...          # секрет для перевірки підпису webhook
APP_BASE_URL=http://127.0.0.1:5000       # base URL для redirect/return (Checkout, Connect onboarding)
CREDIT_PRICE_EUR=1.0                     # ціна одного сервіс-кредиту (= 1 перегляд)

# ──────────────────────────────────────────────
# E-Mail (SMTP) — без цих змінних листи лише логуються (dev)
# ──────────────────────────────────────────────
MAIL_SERVER=                             # напр. smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=                           # SMTP логін
MAIL_PASSWORD=                           # SMTP пароль / app password
MAIL_FROM=DropBid <noreply@dropbid.de>   # адреса відправника
MAIL_USE_TLS=true
MAIL_USE_SSL=false
